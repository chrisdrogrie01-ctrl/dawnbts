{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        },
        "badge_tagline": {
          "type": "text",
          "settings": {
            "text": "Bestseller \u00b7 Bundle & Save",
            "text_style": "uppercase"
          }
        },
        "benefits": {
          "type": "text",
          "settings": {
            "text": "\u2705 Professional Grade \u00b7 \ud83d\ude9a Fast Shipping \u00b7 \ud83d\udcaa Designed for Athletes \u00b7 \ud83d\udd04 30-day Returns",
            "text_style": "body"
          }
        },
        "how_to_use": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How to Use",
            "icon": "check_mark",
            "content": "<p>Use before training to prime movement, between sets for activation, and after training to support recovery.</p>",
            "page": ""
          }
        },
        "specs": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Specs & Materials",
            "icon": "clipboard",
            "content": "<p>Built with durable, athlete-tested materials for repeated gym, studio, and travel use.</p>",
            "page": ""
          }
        },
        "shipping_returns": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "<p>Fast shipping, free shipping over \u20ac75, and a 30-day return window.</p>",
            "page": ""
          }
        }
      },
      "block_order": [
        "badge_tagline",
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "benefits",
        "description",
        "how_to_use",
        "specs",
        "shipping_returns",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-4",
        "media_position": "left",
        "gallery_layout": "thumbnail_slider",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "hover",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": true,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "disclosures": {
      "type": "disclosures",
      "settings": {
        "padding_top": 36,
        "padding_bottom": 0
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Complete your recovery kit",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-4",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "disclosures",
    "related-products"
  ]
}
