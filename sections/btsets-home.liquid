{{ 'section-btsets-home.css' | asset_url | stylesheet_tag }}

{% liquid
  assign trust_blocks = section.blocks | where: 'type', 'trust_item'
  assign collection_blocks = section.blocks | where: 'type', 'collection_card'
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign review_blocks = section.blocks | where: 'type', 'review'
%}

<section class="btsets-home color-{{ section.settings.color_scheme }} gradient" style="--btsets-accent: {{ section.settings.accent_color }}; --btsets-secondary: {{ section.settings.secondary_accent }}; --btsets-speed: {{ section.settings.animation_speed }}s;">
  <div class="btsets-glow btsets-glow--one" aria-hidden="true"></div>
  <div class="btsets-glow btsets-glow--two" aria-hidden="true"></div>

  <div class="btsets-hero page-width btsets-reveal">
    <div class="btsets-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="btsets-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.cta_label != blank %}
        <a class="button button--primary btsets-button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
    <div class="btsets-hero__media btsets-float">
      {% if section.settings.hero_video != blank %}
        {{ section.settings.hero_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1400x' }}
      {% elsif section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '500, 750, 1000, 1400', sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.heading }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>

  {% if trust_blocks.size > 0 %}
    <div class="btsets-trust" aria-label="Store benefits">
      <div class="btsets-trust__track">
        {% for i in (1..2) %}
          {% for block in trust_blocks %}
            <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="page-width btsets-stack">
    <div class="btsets-section-heading btsets-reveal">
      {% if section.settings.collections_eyebrow != blank %}
        <p class="btsets-eyebrow">{{ section.settings.collections_eyebrow }}</p>
      {% endif %}
      {% if section.settings.collections_heading != blank %}
        <h2>{{ section.settings.collections_heading }}</h2>
      {% endif %}
    </div>

    {% if collection_blocks.size > 0 %}
      <div class="btsets-collections">
        {% for block in collection_blocks %}
          <a class="btsets-card btsets-reveal" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '350, 500, 700', sizes: '(min-width: 750px) 33vw, 100vw', alt: block.settings.title }}
            {% endif %}
            <span>{{ block.settings.title }}</span>
            <small>{{ block.settings.text }}</small>
          </a>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.bundle_heading != blank %}
      <div class="btsets-bundle btsets-reveal">
        <div>
          {% if section.settings.bundle_badge != blank %}
            <span class="btsets-badge">{{ section.settings.bundle_badge }}</span>
          {% endif %}
          <h2>{{ section.settings.bundle_heading }}</h2>
          <p>{{ section.settings.bundle_text }}</p>
        </div>
        {% if section.settings.bundle_cta_label != blank %}
          <a class="button button--primary btsets-button" href="{{ section.settings.bundle_link }}">{{ section.settings.bundle_cta_label }}</a>
        {% endif %}
      </div>
    {% endif %}

    {% if step_blocks.size > 0 %}
      <div class="btsets-how">
        {% for block in step_blocks %}
          <div class="btsets-card btsets-reveal" {{ block.shopify_attributes }}>
            <strong>{{ block.settings.number }}</strong>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if review_blocks.size > 0 %}
      <div class="btsets-reviews">
        {% for block in review_blocks %}
          <article class="btsets-card btsets-reveal" {{ block.shopify_attributes }}>
            <span>{{ block.settings.stars }}</span>
            <p>{{ block.settings.quote }}</p>
            <strong>{{ block.settings.author }}</strong>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.newsletter_heading != blank %}
      <div class="btsets-newsletter btsets-reveal">
        <div>
          {% if section.settings.newsletter_eyebrow != blank %}
            <p class="btsets-eyebrow">{{ section.settings.newsletter_eyebrow }}</p>
          {% endif %}
          <h2>{{ section.settings.newsletter_heading }}</h2>
        </div>
        {% form 'customer', class: 'btsets-newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder }}" aria-label="{{ section.settings.newsletter_placeholder }}" required>
          <button class="button button--primary btsets-button" type="submit">{{ section.settings.newsletter_button }}</button>
        {% endform %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "BTSETS homepage",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-4" },
    { "type": "color", "id": "accent_color", "label": "Primary accent", "default": "#1578ff" },
    { "type": "color", "id": "secondary_accent", "label": "Secondary accent", "default": "#35ff68" },
    { "type": "range", "id": "animation_speed", "min": 12, "max": 40, "step": 2, "unit": "s", "label": "Marquee animation speed", "default": 24 },
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Between The Sets" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recover Harder. Perform Better." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium recovery tools and training accessories for athletes who take every set seriously." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero fallback image" },
    { "type": "video", "id": "hero_video", "label": "Hero autoplay video" },
    { "type": "header", "content": "Collections" },
    { "type": "text", "id": "collections_eyebrow", "label": "Collections eyebrow", "default": "Shop by goal" },
    { "type": "text", "id": "collections_heading", "label": "Collections heading", "default": "Recovery gear built for the work between the sets." },
    { "type": "header", "content": "Bundle spotlight" },
    { "type": "text", "id": "bundle_badge", "label": "Badge", "default": "Save 20%" },
    { "type": "text", "id": "bundle_heading", "label": "Heading", "default": "Recovery Starter Pack" },
    { "type": "textarea", "id": "bundle_text", "label": "Text", "default": "Everything athletes need to loosen tight muscles, prime movement patterns, and bounce back faster after heavy sessions." },
    { "type": "text", "id": "bundle_cta_label", "label": "CTA label", "default": "Build your kit" },
    { "type": "url", "id": "bundle_link", "label": "CTA link" },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_eyebrow", "label": "Eyebrow", "default": "Join the crew" },
    { "type": "text", "id": "newsletter_heading", "label": "Heading", "default": "Get 10% off your first order" },
    { "type": "text", "id": "newsletter_placeholder", "label": "Email placeholder", "default": "Email address" },
    { "type": "text", "id": "newsletter_button", "label": "Button label", "default": "Sign up" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust bar item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "⚡ Free shipping over €75" }
      ]
    },
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Resistance Bands" },
        { "type": "text", "id": "text", "label": "Text", "default": "Mobility, warm-ups, strength" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "step",
      "name": "How it works step",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Choose your gear" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Select bands, tools, or bundles for your training style." }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "stars", "label": "Stars", "default": "★★★★★" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The bands are sturdy and the massage gun lives in my gym bag." },
        { "type": "text", "id": "author", "label": "Author", "default": "— Marco, Hyrox athlete" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BTSETS homepage",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "⚡ Free shipping over €75" } },
        { "type": "trust_item", "settings": { "text": "🌍 Ships to 41 countries" } },
        { "type": "trust_item", "settings": { "text": "⭐ 4.9/5 Reviews" } },
        { "type": "trust_item", "settings": { "text": "🔄 30-day returns" } },
        { "type": "collection_card", "settings": { "title": "Resistance Bands", "text": "Mobility, warm-ups, strength" } },
        { "type": "collection_card", "settings": { "title": "Massage Guns", "text": "Deep tissue recovery" } },
        { "type": "collection_card", "settings": { "title": "Recovery Bundles", "text": "Save on complete kits" } },
        { "type": "step", "settings": { "number": "01", "title": "Choose your gear", "text": "Select bands, tools, or bundles for your training style." } },
        { "type": "step", "settings": { "number": "02", "title": "Train & recover", "text": "Use pro-grade equipment before, during, and after workouts." } },
        { "type": "step", "settings": { "number": "03", "title": "Feel the difference", "text": "Move better, recover harder, and perform with confidence." } },
        { "type": "review", "settings": { "quote": "The bands are sturdy and the massage gun lives in my gym bag.", "author": "— Marco, Hyrox athlete" } },
        { "type": "review", "settings": { "quote": "Premium feel, fast shipping, and exactly what I needed for recovery days.", "author": "— Sofia, PT" } },
        { "type": "review", "settings": { "quote": "The bundle made it simple to upgrade my warm-up and cooldown.", "author": "— Liam, runner" } }
      ]
    }
  ]
}
{% endschema %}
