{{ 'section-btsets-home.css' | asset_url | stylesheet_tag }}

<section class="btsets-home color-{{ section.settings.color_scheme }} gradient">
  <div class="btsets-hero page-width">
    <div class="btsets-hero__copy">
      <p class="btsets-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <a class="button button--primary btsets-button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
    </div>
    <div class="btsets-hero__media">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '500, 750, 1000, 1400', sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.heading }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>

  <div class="btsets-trust" aria-label="Store benefits">
    <div class="btsets-trust__track">
      <span>⚡ Free shipping over €75</span><span>🌍 Ships to 41 countries</span><span>⭐ 4.9/5 Reviews</span><span>🔄 30-day returns</span>
      <span>⚡ Free shipping over €75</span><span>🌍 Ships to 41 countries</span><span>⭐ 4.9/5 Reviews</span><span>🔄 30-day returns</span>
    </div>
  </div>

  <div class="page-width btsets-stack">
    <div class="btsets-section-heading">
      <p class="btsets-eyebrow">Shop by goal</p>
      <h2>Recovery gear built for the work between the sets.</h2>
    </div>
    <div class="btsets-collections">
      <a href="{{ section.settings.collection_1_link }}"><span>Resistance Bands</span><small>Mobility, warm-ups, strength</small></a>
      <a href="{{ section.settings.collection_2_link }}"><span>Massage Guns</span><small>Deep tissue recovery</small></a>
      <a href="{{ section.settings.collection_3_link }}"><span>Recovery Bundles</span><small>Save on complete kits</small></a>
    </div>

    <div class="btsets-bundle">
      <div>
        <span class="btsets-badge">Save 20%</span>
        <h2>Recovery Starter Pack</h2>
        <p>Everything athletes need to loosen tight muscles, prime movement patterns, and bounce back faster after heavy sessions.</p>
      </div>
      <a class="button button--primary btsets-button" href="{{ section.settings.bundle_link }}">Build your kit</a>
    </div>

    <div class="btsets-how">
      <div><strong>01</strong><h3>Choose your gear</h3><p>Select bands, tools, or bundles for your training style.</p></div>
      <div><strong>02</strong><h3>Train & recover</h3><p>Use pro-grade equipment before, during, and after workouts.</p></div>
      <div><strong>03</strong><h3>Feel the difference</h3><p>Move better, recover harder, and perform with confidence.</p></div>
    </div>

    <div class="btsets-reviews">
      <article><span>★★★★★</span><p>“The bands are sturdy and the massage gun lives in my gym bag.”</p><strong>— Marco, Hyrox athlete</strong></article>
      <article><span>★★★★★</span><p>“Premium feel, fast shipping, and exactly what I needed for recovery days.”</p><strong>— Sofia, PT</strong></article>
      <article><span>★★★★★</span><p>“The bundle made it simple to upgrade my warm-up and cooldown.”</p><strong>— Liam, runner</strong></article>
    </div>

    <div class="btsets-newsletter">
      <div><p class="btsets-eyebrow">Join the crew</p><h2>Get 10% off your first order</h2></div>
      {% form 'customer', class: 'btsets-newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Email address" aria-label="Email address" required>
        <button class="button button--primary btsets-button" type="submit">Sign up</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{"name":"BTSETS homepage","settings":[{"type":"color_scheme","id":"color_scheme","label":"Color scheme","default":"scheme-4"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Between The Sets"},{"type":"text","id":"heading","label":"Heading","default":"Recover Harder. Perform Better."},{"type":"textarea","id":"subheading","label":"Subheading","default":"Premium recovery tools and training accessories for athletes who take every set seriously."},{"type":"text","id":"cta_label","label":"CTA label","default":"Shop Now"},{"type":"url","id":"cta_link","label":"CTA link"},{"type":"image_picker","id":"hero_image","label":"Hero image"},{"type":"url","id":"collection_1_link","label":"Resistance bands link"},{"type":"url","id":"collection_2_link","label":"Massage guns link"},{"type":"url","id":"collection_3_link","label":"Bundles link"},{"type":"url","id":"bundle_link","label":"Bundle link"}],"presets":[{"name":"BTSETS homepage"}]}
{% endschema %}
